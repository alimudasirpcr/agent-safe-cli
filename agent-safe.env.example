# agent-safe configuration
# Copy this to .agent-safe.env in your project root or ~/.agent-safe/.env
# Values here override defaults but are overridden by environment variables

# AI Provider: claude (default), openai, gemini, ollama, custom
AGENT_SAFE_PROVIDER=claude

# Model name (provider-specific)
# AGENT_SAFE_MODEL=gpt-4o
# AGENT_SAFE_MODEL=gemini-2.0-flash
# AGENT_SAFE_MODEL=llama3

# Custom AI command (only used with --provider custom)
# {{PROMPT}}      → removed from command, prompt piped via stdin (recommended)
# {{PROMPT_FILE}} → replaced with a temp file path containing the prompt
# AGENT_SAFE_AI_CMD=ollama run llama3 {{PROMPT}}
# AGENT_SAFE_AI_CMD=my-ai-tool --file {{PROMPT_FILE}}
# NOTE: "ollama launch claude" is an interactive launcher, not suitable for batch use.
#       Use --provider ollama instead, or --provider custom with "ollama run MODEL".

# API keys (required for openai and gemini providers)
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Max turns per Claude call (Claude provider only)
# AGENT_SAFE_MAX_TURNS=40

# Prompts directory override (default: ./prompts/ next to the script)
# AGENT_SAFE_PROMPTS_DIR=/path/to/prompts

# Skills directory override (default: ./skills/ next to the script)
# AGENT_SAFE_SKILLS_DIR=/path/to/skills